{
  "name": "files-assets-linker-editor",
  "displayName": "Assets Linker (Monaco UI)",
  "description": "Link external HTML, CSS, JS assets into your project",
  "publisher": "AlenToma",
  "version": "0.0.2",
  "repository": "https://github.com/1-AlenToma/files-assets-linker-editor",
  "engines": {
    "vscode": "^1.80.0"
  },
  "scripts": {
    "_publish": "vsce publish"
  },
  "keywords": [
    "webview",
    "assets",
    "linker",
    "bundler",
    "html",
    "css",
    "javascript",
    "react-native",
    "monaco",
    "editor",
    "file-sync",
    "live-assets",
    "ui-tooling",
    "frontend",
    "development-tools"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:assetLinker.openEditor",
    "onCommand:assetLinker.build"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "assetLinker.openEditor",
        "title": "Assets Linker: Open Editor"
      },
      {
        "command": "assetLinker.build",
        "title": "Assets Linker: Build"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "assetLinker.openEditor",
          "when": "resourceFilename == file-assets-linker.json"
        }
      ]
    }
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "html-minifier-terser": "^7.2.0",
    "js-beautify": "^1.15.4",
    "lightningcss": "^1.32.0",
    "monaco-editor": "^0.55.1"
  }
}
